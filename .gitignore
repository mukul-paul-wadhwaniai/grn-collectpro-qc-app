auth_user.csv

# ── Pipeline outputs (large parquets + GCP-mirrored images) ─────────
/data/
*.parquet

# ── Web app runtime artifacts ───────────────────────────────────────
web-app/static/images/
web-app/reviews.db-wal
web-app/reviews.db-shm
web-app/reviews.db.bak-*
web-app/tmp/

# ── Logs ────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

static/*
