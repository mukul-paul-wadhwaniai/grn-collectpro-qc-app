# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ────────────────────────────────────────────
venv/
.venv/
env/
.env
.env.*
!.env.example

# ── Secrets / config (move credentials to .env) ─────────────────────
database.ini

# ── Raw DB dumps (large, regenerated by connect.py) ─────────────────
